---
import { SITE } from '../config';
import { generateLineQrSvg } from '../utils/qr';

const qrSvg = await generateLineQrSvg(SITE.LINE_URL);
---
<section class="bg-base-alt py-20 md:py-28" id="contact-block">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-ink-strong text-center mb-12">
      お気軽にご相談ください
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Phone -->
      <div class="bg-white rounded-2xl shadow-sm p-8 text-center">
        <div class="mb-4">
          <svg class="w-10 h-10 mx-auto text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <p class="text-sm mb-2">お電話でのご相談</p>
        <a
          href={`tel:${SITE.TEL}`}
          class="block font-heading text-3xl md:text-4xl font-bold text-accent hover:text-accent-hover transition-colors min-h-[44px] leading-tight"
        >
          {SITE.TEL}
        </a>
        <p class="text-sm mt-2 text-ink/60">{SITE.TEL_HOURS}</p>
      </div>

      <!-- LINE -->
      <div class="bg-white rounded-2xl shadow-sm p-8 text-center">
        <div class="mb-4">
          <svg class="w-10 h-10 mx-auto text-line" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
          </svg>
        </div>
        <p class="text-sm mb-3">LINEでのご相談</p>

        <a
          href={SITE.LINE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="md:hidden inline-block bg-line text-white font-bold px-8 py-3 rounded-full hover:opacity-90 transition-opacity min-h-[44px]"
        >
          LINEで友だち追加
        </a>
        <p class="md:hidden text-xs mt-2 text-ink/50">スマホの方はタップしてください</p>

        <div class="hidden md:block">
          <div class="inline-block bg-white p-2 rounded-lg" set:html={qrSvg} />
          <p class="text-xs mt-2 text-ink/50">パソコンの方はQRコードを読み取り</p>
        </div>
      </div>

      <!-- Mail -->
      <div class="bg-white rounded-2xl shadow-sm p-8 text-center">
        <div class="mb-4">
          <svg class="w-10 h-10 mx-auto text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="text-sm mb-4">メールでのご相談</p>
        <a
          href="/contact"
          class="inline-block bg-accent text-white font-bold px-8 py-3 rounded-full hover:bg-accent-hover transition-colors min-h-[44px]"
        >
          お問い合わせフォーム
        </a>
        <p class="text-sm mt-2 text-ink/60">24時間受付</p>
      </div>
    </div>
  </div>
</section>
